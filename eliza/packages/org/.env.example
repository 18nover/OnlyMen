# ONLYMEN Engineering Organization Configuration

# ── Model Backend ──
# Default: chat is served by the local `claude` CLI subscription via
# plugin-cli-inference — no API keys required. This is what the run-eliza
# driver (eliza/.claude/skills/run-eliza/driver.sh) and `bin/org` set up.
# Prerequisite: a logged-in claude CLI (~/.claude/.credentials.json).
# ELIZA_RUN_BACKEND selects the CLI backend (claude-sdk | claude | codex);
# the driver exports it as ELIZA_CHAT_VIA_CLI at boot.
ELIZA_RUN_BACKEND=claude-sdk
# Required alongside a CLI backend: native planner tools must be off or the
# planner errors out ("Something glitched…" in chat).
ELIZA_PLANNER_NATIVE_TOOLS=0
# Server port used by the driver and bin/org (default 2139).
#ELIZA_RUN_PORT=2139

# ── Alternative: local Ollama inference (NOT the default) ──
# Requires serious GPU/VRAM (llama3.1:70b ≈ 40GB+ quantized) — this will NOT
# run on a Raspberry Pi or a typical laptop; see docs/HANDOFF.md. Uncomment
# to use on a real GPU machine.
#OLLAMA_BASE_URL=http://localhost:11434
#DEFAULT_MODEL=llama3.1:70b
#SMALL_MODEL=llama3.1:8b
#EMBEDDING_MODEL=nomic-embed-text
# Agent-specific overrides:
#ATLAS_MODEL=llama3.1:70b
#ECHO_MODEL=llama3.1:70b
#NOVA_MODEL=codellama:34b
#PIXEL_MODEL=llama3.1:8b
#FORGE_MODEL=codellama:34b
#LEXI_MODEL=llama3.1:8b
#VISION_MODEL=llama3.1:70b
#SENTINEL_MODEL=llama3.1:70b
#CIRCUIT_MODEL=codellama:34b
#PULSE_MODEL=codellama:34b
#COMPASS_MODEL=llama3.1:8b
#SCRIBE_MODEL=llama3.1:8b
#PRISM_MODEL=llama3.1:8b

# ── ONLYMEN Project Paths ──
ONLYMEN_APP_PATH=../app
ONLYMEN_ATPROTO_PATH=../atproto

# ── Database ──
DATABASE_URL=postgresql://localhost:5432/onlymen_org

# ── Redis (for shared memory / event bus) ──
REDIS_URL=redis://localhost:6379

# ── Logging ──
LOG_LEVEL=info
LOG_FORMAT=structured

# ── Security ──
SECRET_KEY=change-me-in-production
API_KEY=change-me-in-production
